{
  "name": "spirebound",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:ci": "node test/test_ci_contract.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node test/test_engine.js",
    "test:progression": "node tools/emberglass-pacing.mjs",
    "test:e2e": "npm run test:e2e:disk && npm run test:e2e:random-agent && npm run test:e2e:main && npm run test:e2e:visual",
    "test:e2e:smoke": "playwright test --project=desktop --no-deps --grep @smoke --workers=2",
    "test:e2e:disk": "playwright test bfeditor --project=bfeditor-disk --workers=1",
    "test:e2e:random-agent": "playwright test battle --config=playwright.random-agent.config.js --project=desktop --grep \"random-agent mini-run\" --workers=1 --no-deps",
    "test:e2e:main": "playwright test --project=desktop --project=portrait --project=landscape --no-deps --grep-invert \"random-agent mini-run|visual\\.spec\\.js|@serial\"",
    "test:e2e:serial": "playwright test --project=desktop --workers=1 --no-deps --grep @serial",
    "test:e2e:visual": "playwright test visual --project=desktop --project=portrait --project=landscape --workers=1 --no-deps",
    "test:e2e:visual:project": "playwright test visual --workers=1 --no-deps",
    "test:e2e:update": "playwright test visual --update-snapshots --workers=1 --no-deps",
    "test:e2e:perf": "PERF=1 playwright test perf --project=portrait --workers=1 --no-deps",
    "spike:mesh": "node tools/spike-serve.mjs",
    "gen:batch": "node tools/gen-batch.mjs",
    "gen:icons": "tools/gen-icons.sh"
  },
  "dependencies": {
    "@fontsource/alegreya": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "three": "^0.185.1",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
