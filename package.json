{
  "name": "spirebound",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:ci": "node test/test_ci_contract.mjs && npm run test:boundaries && node test/test_baseline_tools.mjs",
    "test:boundaries": "node test/test_module_boundaries.mjs",
    "build": "vite build",
    "release": "node tools/release.mjs",
    "release:build": "SPIRE_RELEASE=1 vite build",
    "preview": "vite preview",
    "test": "node test/test_engine.js",
    "sim": "node tools/sim/runner.mjs",
    "sim:smoke": "node tools/sim/runner.mjs --smoke",
    "test:round5:standing": "node tools/run-round5-standing-gates.mjs",
    "test:progression": "node tools/emberglass-pacing.mjs",
    "test:fonts": "node tools/verify-round5-fonts.mjs --check",
    "test:budget": "node tools/check-bundle-budget.mjs",
    "content:compile": "node tools/compile-content-registrations.mjs",
    "test:content-registrations": "node tools/compile-content-registrations.mjs --check",
    "test:act-coupling": "node tools/check-act-coupling.mjs",
    "test:e2e": "npm run test:e2e:nonvisual && npm run test:e2e:visual",
    "test:e2e:nonvisual": "npm run test:e2e:disk && npm run test:e2e:random-agent && npm run test:e2e:pool && npm run test:e2e:serial",
    "test:e2e:trace-production": "playwright test --config=playwright.trace-production.config.js",
    "test:e2e:smoke": "playwright test --project=desktop --no-deps --grep @smoke --workers=2",
    "test:e2e:bfuieditor-disk": "playwright test bfuieditor --project=bfuieditor-disk --workers=1",
    "test:e2e:disk": "playwright test bfeditor --project=bfeditor-disk --workers=1 && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:bfuieditor-disk",
    "test:e2e:content-disk": "playwright test content-manager --project=content-manager-disk --workers=1",
    "test:e2e:random-agent": "playwright test battle --config=playwright.random-agent.config.js --project=desktop --grep \"random-agent mini-run\" --workers=1 --no-deps",
    "test:e2e:pool": "SPIREBOUND_E2E_SUITE=pool playwright test --project=desktop --project=portrait --project=landscape --no-deps --grep-invert \"random-agent mini-run|@serial\"",
    "test:e2e:serial": "playwright test --project=desktop --workers=1 --no-deps --grep @serial",
    "test:e2e:visual": "playwright test visual --project=desktop --project=portrait --project=landscape --workers=1 --no-deps",
    "test:e2e:visual:project": "playwright test visual --workers=1 --no-deps",
    "test:e2e:webkit": "npm run test:e2e:webkit-core && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:webkit-lab && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:webkit-screens",
    "test:e2e:webkit-core": "npm run test:e2e:webkit-core-iphone && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:webkit-core-ipad",
    "test:e2e:webkit-core-iphone": "playwright test stage --project=iphone-webkit --workers=1 --no-deps && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:webkit-trace -- --project=iphone-webkit --shard=1/2 && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:webkit-trace -- --project=iphone-webkit --shard=2/2",
    "test:e2e:webkit-core-ipad": "playwright test stage --project=ipad-webkit --workers=1 --no-deps && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:webkit-trace -- --project=ipad-webkit --shard=1/2 && node tools/run-with-strict-e2e-port.mjs -- npm run test:e2e:webkit-trace -- --project=ipad-webkit --shard=2/2",
    "test:e2e:webkit-trace": "playwright test trace --workers=1 --no-deps",
    "test:e2e:webkit-lab": "playwright test lab theme-profile --project=iphone-webkit --project=ipad-webkit --workers=1 --no-deps",
    "test:e2e:webkit-screens": "playwright test production-profile p6-screens --project=iphone-webkit --project=ipad-webkit --workers=1 --no-deps",
    "capture:round5:contact-sheets": "node tools/capture-round5-contact-sheets.mjs",
    "capture:store-kit": "node tools/capture-store-kit.mjs",
    "project:round5:layout": "node tools/run-with-strict-e2e-port.mjs -- node tools/project-round5-layout.mjs",
    "project:round5:layout:golden": "LAYOUT_PROJECTION_MODE=golden node tools/run-with-strict-e2e-port.mjs -- node tools/project-round5-layout.mjs",
    "project:round5:layout:compare": "LAYOUT_PROJECTION_MODE=compare node tools/run-with-strict-e2e-port.mjs -- node tools/project-round5-layout.mjs",
    "test:layout-projection": "node test/test_screen_layout_projection.mjs",
    "test:e2e:leak": "playwright test leak --project=desktop --project=iphone-webkit --project=ipad-webkit --workers=1 --no-deps",
    "test:e2e:update": "playwright test visual --update-snapshots --project=desktop --project=portrait --project=landscape --workers=1 --no-deps",
    "test:e2e:perf": "PERF=1 playwright test perf --project=portrait --workers=1 --no-deps",
    "test:e2e:perf:full": "PERF=1 PERF_TIER=full playwright test perf --project=desktop --workers=1 --no-deps",
    "spike:mesh": "node tools/spike-serve.mjs",
    "gen:batch": "node tools/gen-batch.mjs",
    "gen:icons": "tools/gen-icons.sh"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.2",
    "@fontsource/alegreya": "5.2.8",
    "@fontsource/cinzel": "5.2.8",
    "pixi.js": "8.19.0",
    "three": "^0.185.1",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@playwright/test": "^1.61.1"
  }
}
