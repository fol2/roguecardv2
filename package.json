{
  "name": "spirebound",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node test/test_engine.js",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:perf": "PERF=1 playwright test perf --workers=1",
    "test:e2e:bfeditor-disk": "BFEDITOR_DISK=1 playwright test bfeditor --project=desktop --grep \"Save writes layout\" --workers=1",
    "spike:mesh": "node tools/spike-serve.mjs",
    "gen:batch": "node tools/gen-batch.mjs",
    "gen:icons": "tools/gen-icons.sh"
  },
  "dependencies": {
    "@fontsource/alegreya": "^5.2.8",
    "@fontsource/cinzel": "^5.2.8",
    "three": "^0.185.1",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
