from PIL import Image
from collections import deque
p='untouched.png'
im=Image.open(p).convert('RGBA')
w,h=im.size
pix=im.load()

def is_keyish(px):
    r,g,b,a=px
    if a < 10:
        return True
    # Generated background is near #ff00ff but may include antialias/noise.
    return (r >= 150 and b >= 145 and g <= 105 and abs(r-b) <= 90)

seen=bytearray(w*h)
q=deque()
for x in range(w):
    for y in (0,h-1):
        i=y*w+x
        if not seen[i] and is_keyish(pix[x,y]):
            seen[i]=1; q.append((x,y))
for y in range(h):
    for x in (0,w-1):
        i=y*w+x
        if not seen[i] and is_keyish(pix[x,y]):
            seen[i]=1; q.append((x,y))
while q:
    x,y=q.popleft()
    for nx,ny in ((x+1,y),(x-1,y),(x,y+1),(x,y-1)):
        if 0 <= nx < w and 0 <= ny < h:
            i=ny*w+nx
            if not seen[i] and is_keyish(pix[nx,ny]):
                seen[i]=1; q.append((nx,ny))
count=sum(seen)
out=im.copy(); op=out.load()
for y in range(h):
    base=y*w
    for x in range(w):
        if seen[base+x]:
            op[x,y]=(255,0,255,255)
out.save(p)
print(f'normalised {count} background pixels ({count/(w*h):.1%}) to #ff00ff')
