from PIL import Image
from collections import deque
path = 'beacon.png'
img = Image.open(path).convert('RGBA')
w, h = img.size
pix = img.load()
seen = bytearray(w*h)
q = deque()

def idx(x, y): return y*w + x

def is_bg(px):
    r, g, b, a = px
    return a > 0 and r >= 175 and b >= 175 and g <= 90 and abs(r - b) <= 95

for x in range(w):
    for y in (0, h-1):
        if is_bg(pix[x, y]):
            seen[idx(x, y)] = 1
            q.append((x, y))
for y in range(h):
    for x in (0, w-1):
        if not seen[idx(x, y)] and is_bg(pix[x, y]):
            seen[idx(x, y)] = 1
            q.append((x, y))

count = 0
while q:
    x, y = q.popleft()
    pix[x, y] = (255, 0, 255, 255)
    count += 1
    for nx, ny in ((x+1,y),(x-1,y),(x,y+1),(x,y-1)):
        if 0 <= nx < w and 0 <= ny < h:
            i = idx(nx, ny)
            if not seen[i] and is_bg(pix[nx, ny]):
                seen[i] = 1
                q.append((nx, ny))
img.save(path)
print('normalised_background_pixels', count)
print('size', w, h)
for p in [(0,0),(w-1,0),(0,h-1),(w-1,h-1),(w//2,0),(0,h//2)]:
    print(p, '#%02x%02x%02x' % img.getpixel(p)[:3])
