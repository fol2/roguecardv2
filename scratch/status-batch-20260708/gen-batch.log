/bin/zsh -lc "python3 - <<'PY'
from PIL import Image
from collections import deque
path='emberflow.png'
img=Image.open(path).convert('RGB')
w,h=img.size
px=img.load()

def is_keyish(c):
    r,g,b = c
    return r >= 180 and b >= 180 and g <= 90 and abs(r-b) <= 70

seen = bytearray(w*h)
q = deque()
for x in range(w):
    for y in (0, h-1):
        i=y*w+x
        if not seen[i] and is_keyish(px[x,y]):
            seen[i]=1; q.append((x,y))
for y in range(h):
    for x in (0, w-1):
        i=y*w+x
        if not seen[i] and is_keyish(px[x,y]):
            seen[i]=1; q.append((x,y))

count=0
while q:
    x,y=q.popleft(); count+=1
    for nx,ny in ((x+1,y),(x-1,y),(x,y+1),(x,y-1)):
        if 0 <= nx < w and 0 <= ny < h:
            i=ny*w+nx
            if not seen[i] and is_keyish(px[nx,ny]):
                seen[i]=1; q.append((nx,ny))

for y in range(h):
    base=y*w
    for x in range(w):
        if seen[base+x]:
            px[x,y]=(255,0,255)
img.save(path)
print('set_pixels', count, 'of', w*h)
