from PIL import Image
src = Image.open('/private/tmp/spirebound-imagegen/cursedIdol_chromakey.png').convert('RGBA')
matte = Image.open('/private/tmp/spirebound-imagegen/cursedIdol_t45_o140_ec2.png').convert('RGBA')
key = (250, 3, 229)
out = Image.new('RGBA', src.size)
sp = src.load(); mp = matte.load(); op = out.load()
w,h = src.size
for y in range(h):
    for x in range(w):
        r,g,b,_ = sp[x,y]
        _,_,_,a = mp[x,y]
        if a == 0:
            op[x,y] = (0,0,0,0)
        elif a < 255:
            af = max(a / 255.0, 0.03)
            rr = int(round((r - key[0] * (1 - af)) / af))
            gg = int(round((g - key[1] * (1 - af)) / af))
            bb = int(round((b - key[2] * (1 - af)) / af))
            rr = max(0, min(255, rr)); gg = max(0, min(255, gg)); bb = max(0, min(255, bb))
            # If the recovered colour is still magenta-dominant, treat it as edge contamination and darken it.
            if rr > 90 and bb > 90 and gg < 100 and rr - gg > 45 and bb - gg > 45:
                base = min(80, max(0, gg))
                rr = int(base * 0.8); bb = int(base * 0.9); gg = base
            op[x,y] = (rr, gg, bb, a)
        else:
            op[x,y] = mp[x,y]
out.save('/private/tmp/spirebound-imagegen/cursedIdol_decontam.png')
