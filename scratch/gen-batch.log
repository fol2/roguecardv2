from PIL import Image
from pathlib import Path
p=Path('leechBlade.png')
im=Image.open(p).convert('RGBA')
w,h=im.size
alpha=im.getchannel('A')
vals=list(alpha.getdata())
transparent=sum(a==0 for a in vals)
partial=sum(0<a<255 for a in vals)
opaque=sum(a==255 for a in vals)
bbox=alpha.getbbox()
corners=[im.getpixel(xy)[3] for xy in [(0,0),(w-1,0),(0,h-1),(w-1,h-1)]]
# rough green fringe check: pixels near edges with green much greater than red/blue and some alpha
fringe=0
semi=0
for r,g,b,a in im.getdata():
    if 0<a<255:
        semi+=1
        if g>160 and g>r+50 and g>b+50:
            fringe+=1
print(f'path={p.resolve()}')
print(f'size={w}x{h} mode={im.mode}')
print(f'alpha transparent={transparent} partial={partial} opaque={opaque}')
print(f'alpha_bbox={bbox} corner_alpha={corners}')
print(f'semi_green_fringe={fringe}/{semi}')
